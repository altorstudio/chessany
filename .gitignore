# dependencies
node_modules/

# build output
dist/
*.local

# editor / OS
.DS_Store
._*
.vscode/
.idea/
*.code-workspace

# Capacitor iOS shell (generated by `npx cap add ios`). The Android project IS
# tracked (the release workflow builds an APK from it); its own .gitignore plus
# the rules below keep build artifacts and the large native binary out.
/ios/

# Engine binaries (Stockfish) are fetched via `npm run engines:fetch`.
public/engines/

# logs
npm-debug.log*
*.log
*.tmp

# TypeScript incremental build info
*.tsbuildinfo

# Piece sets (SVGs) are fetched via `npm run pieces:fetch`.
public/pieces/

# Sound samples are fetched via `npm run sounds:fetch` — except board/, the
# default set (Kenney CC0 wood impacts), which is committed.
public/sounds/*
!public/sounds/board/
