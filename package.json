{
  "name": "chessany",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Play and analyze chess against Stockfish, on device (web + iOS + Android).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "engines:fetch": "node scripts/fetch-engines.mjs",
    "postinstall": "node scripts/fetch-engines.mjs && node scripts/fetch-pieces.mjs && node scripts/fetch-sounds.mjs",
    "cap:sync": "cap sync",
    "pieces:fetch": "node scripts/fetch-pieces.mjs",
    "sounds:fetch": "node scripts/fetch-sounds.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/status-bar": "^8.0.2",
    "chess.js": "^1.0.0",
    "chessground": "^9.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
