# Cross-origin isolation enables SharedArrayBuffer, which the multi-threaded
# WASM Stockfish needs (registry.ts checks `crossOriginIsolated`). Without it the
# app still runs on the single-threaded engine. `credentialless` (not
# `require-corp`) lets cross-origin assets — Google Fonts, jsdelivr piece images —
# still load; Safari, which lacks credentialless, simply uses single-threaded.
/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless

# Hashed build assets are immutable — cache them hard.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Engine binaries (fetched at build time) are large and stable — cache them too.
/engines/*
  Cache-Control: public, max-age=604800
